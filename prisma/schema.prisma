// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Stable {
  id String @id
  isDefault Boolean @default(false)
}

model Asset {
  id String @id
}

model JobsHistory {
  id String @id
  name String
  timestamp DateTime
}

model AssetPrices {
  id                 String   @id
  price              Decimal
  prevClosePrice     Decimal
  priceChangePercent Decimal
  timestamp          DateTime
}

model PriceNotifications {
  id String @id
  timestamp DateTime
}

model Trades {
  id BigInt @id
  symbol String
  timestamp DateTime
  qty Decimal
  quoteQty Decimal
  price Decimal
}

model TradesAggr {
  symbol String @id
  qty Decimal
  quoteQty Decimal
  avgPrice Decimal
  timestamp DateTime
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

model WalletBalance {
  symbol    String   @id
  qty       Decimal
  timestamp DateTime
}